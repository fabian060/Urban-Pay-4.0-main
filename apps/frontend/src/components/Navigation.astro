---
// import logoPng from '../assets/logo.png'
---

<!-- TODO: Menu movil -->
<nav class="bg-[#2563EB] text-white fixed top-0 left-0 right-0 z-50">
    <div class="max-w-7xl mx-auto h-16 flex items-center justify-between">
      <div class="flex items-center gap-2 h-full">
        <!-- <img class="w-8 h-8" src={logoPng.src} alt="logo"> -->
        <h2 class="font-medium text-xl">Urb. Country Club Buenaventura</h2>
      </div>
      <div class="flex items-center gap-4">
        <a id="nav-home-link" href="/" class="font-medium hover:underline">Inicio</a>
      </div>
    </div>
</nav>

<script>
  const homeLink = document.getElementById('nav-home-link');
  if (homeLink) {
    fetch('/api/auth/user', { credentials: 'include' })
      .then((res) => {
        if (res.ok) {
          homeLink.style.display = 'none';
        }
      })
      .catch(() => {});
  }
</script>